# Server
CUSTOS_PORT=8080
CUSTOS_ENV=development

# Database
DATABASE_URL=postgres://custos:custos@localhost:5432/custos?sslmode=disable
MIGRATIONS_PATH=migrations

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_EVENTS_TOPIC=custos.events
KAFKA_ANALYSIS_TOPIC=custos.analysis

# AI Provider (claude | openai | gemini | ollama)
CUSTOS_AI_PROVIDER=
CUSTOS_AI_API_KEY=
CUSTOS_AI_MODEL=
CUSTOS_AI_BASE_URL=

# Notifications
GOOGLE_CHAT_WEBHOOK_URL=
SMTP_HOST=131217
SMTP_PORT=587
SMTP_FROM=
WEBHOOK_URL=
