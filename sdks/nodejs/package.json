{
  "name": "@custos/sdk",
  "version": "0.1.0",
  "description": "Custos SDK for Node.js and NestJS — automatic error capture and AI-powered log intelligence",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["custos", "logging", "nestjs", "winston", "pino", "error-tracking"],
  "peerDependencies": {
    "@nestjs/common": ">=9.0.0",
    "winston": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": { "optional": true },
    "winston": { "optional": true }
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/winston": "^2.4.4",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0",
    "winston": "^3.11.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.ts"]
  }
}
